msgstr "Offline — connettiti per visualizzare l'anteprima di questo preset."

#: menu/preset_manager_modal.lua:1609
msgid "Couldn't download '%1'."
msgstr "Impossibile scaricare '%1'."

#: menu/preset_manager_modal.lua:1615
msgid "This preset appears invalid; skipping."
msgstr "Questo preset sembra non valido; verrà ignorato."

#: menu/preset_manager_modal.lua:1638
msgid ""
"'%1' already exists in your library.\n"
"\n"
"Replacing it will overwrite your local copy with the current gallery "
"version. Any local edits will be lost.\n"
"\n"
"Install under a new name to keep both."
msgstr ""
"'%1' esiste già nella tua libreria.\n"
"\n"
"Sostituendolo, la tua copia locale verrà sovrascritta con la versione "
"attuale della galleria. Tutte le modifiche locali andranno perse.\n"
"\n"
"Installa con un nuovo nome per mantenere entrambi."

#: menu/preset_manager_modal.lua:1644
msgid "Replace"
msgstr "Sostituisci"

#: menu/preset_manager_modal.lua:1658
msgid "Install as new name…"
msgstr "Installa con un nuovo nome…"

